{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "mnbvcdere345678909iugr44rfcvbnhge34rfvhtiuyt67yuujh",
    "Issuer": "ConnectSphere.Auth",
    "Audience": "ConnectSphere.Client"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Transforms": [
          { "RequestHeadersCopy": "true" },
          { "X-Forwarded": "Append" }
        ]
      },
      "post-route": {
        "ClusterId": "post-cluster",
        "Match": { "Path": "/api/posts/{**catch-all}" }
      },
      "like-route": {
        "ClusterId": "like-cluster",
        "Match": { "Path": "/api/likes/{**catch-all}" }
      },
      "comment-route": {
        "ClusterId": "comment-cluster",
        "Match": { "Path": "/api/comments/{**catch-all}" }
      },
      "follow-route": {
        "ClusterId": "follow-cluster",
        "Match": { "Path": "/api/follows/{**catch-all}" }
      },
      "notif-route": {
        "ClusterId": "notif-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "feed-route": {
        "ClusterId": "feed-cluster",
        "Match": { "Path": "/api/feed/{**catch-all}" }
      },
      "swagger-auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/swagger-auth/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "swagger-post-route": {
        "ClusterId": "post-cluster",
        "Match": { "Path": "/swagger-post/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "swagger-comment-route": {
        "ClusterId": "comment-cluster",
        "Match": { "Path": "/swagger-comment/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "swagger-feed-route": {
        "ClusterId": "feed-cluster",
        "Match": { "Path": "/swagger-feed/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "swagger-follow-route": {
        "ClusterId": "follow-cluster",
        "Match": { "Path": "/swagger-follow/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "swagger-like-route": {
        "ClusterId": "like-cluster",
        "Match": { "Path": "/swagger-like/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      },
      "swagger-notif-route": {
        "ClusterId": "notif-cluster",
        "Match": { "Path": "/swagger-notif/{**remainder}" },
        "Transforms": [ { "PathPattern": "/swagger/{**remainder}" } ]
      }
    },
    "Clusters": {
      "auth-cluster":    { "Destinations": { "destination1": { "Address": "http://localhost:5288/" } } },
      "post-cluster":    { "Destinations": { "destination1": { "Address": "http://localhost:5111/" } } },
      "like-cluster":    { "Destinations": { "destination1": { "Address": "http://localhost:5074/" } } },
      "comment-cluster": { "Destinations": { "destination1": { "Address": "http://localhost:5016/" } } },
      "follow-cluster":  { "Destinations": { "destination1": { "Address": "http://localhost:5257/" } } },
      "notif-cluster":   { "Destinations": { "destination1": { "Address": "http://localhost:5031/" } } },
      "feed-cluster":    { "Destinations": { "destination1": { "Address": "http://localhost:5001/" } } }
    }
  }
}